{
  "name": "phystack-template-twin-descriptor",
  "version": "0.1.0",
  "description": "Twin descriptor template.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "schema": "cross-env-shell \"shx mkdir -p build/$npm_package_version && npx ts-schema src/schema.ts build/$npm_package_version\"",
    "build": "yarn run schema",
    "pub": "phy descriptor publish"
  },
  "devDependencies": {
    "@phystack/cli": "^6.0.0",
    "@phystack/ts-schema": "^4.4.74",
    "@types/node": "^24.6.0",
    "cross-env": "^7.0.3",
    "shx": "^0.4.0",
    "typescript": "~5.9.3"
  }
}
